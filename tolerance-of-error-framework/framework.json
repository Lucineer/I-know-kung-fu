{
  "tolerance_framework": {
    "definition": "A system that enables approximate execution by determining if an agent's inferred reasoning produces outputs within acceptable tolerance of actual code execution, allowing selective skipping of expensive tool calls while maintaining output quality.",
    "measurement": {
      "methods": {
        "exact": "Byte-level equality comparison (ε < 0.001)",
        "structural": "Schema compliance and structural equivalence (ε < 0.05)",
        "semantic": "Embedding-based similarity scoring (ε < 0.20)",
        "behavioral": "Outcome category matching (ε < 0.50)"
      },
      "metrics": {
        "numerical": {
          "formula": "relative_error = |inferred - actual| / |actual|",
          "range": "[0, ∞)",
          "acceptable_threshold": "depends on tolerance level"
        },
        "text": {
          "formula": "cosine_similarity(embed(inferred), embed(actual))",
          "range": "[0, 1]",
          "acceptable_threshold": {
            "exact": 1.0,
            "close": 0.95,
            "approximate": 0.80,
            "behavioral": 0.50
          }
        },
        "structural": {
          "formula": "schema_compliance * field_match_rate",
          "range": "[0, 1]",
          "checks": ["type_match", "required_fields", "value_ranges"]
        },
        "behavioral": {
          "formula": "(action_match + target_match + outcome_match) / 3",
          "range": "[0, 1]",
          "dimensions": ["action_type", "target_entity", "outcome_category"]
        }
      }
    },
    "calibration": {
      "pipeline": [
        "Collect execution traces (input, inferred, actual, confidence)",
        "Compute error distributions per skill/operation",
        "Set thresholds at desired percentiles (P95 for skip, P80 for fallback)",
        "Validate against accuracy requirements",
        "Monitor drift and trigger recalibration"
      ],
      "parameters": {
        "min_samples": 100,
        "skip_threshold_percentile": 95,
        "fallback_threshold_percentile": 80,
        "retrain_interval_days": 7,
        "drift_detection_window": 1000,
        "confidence_interval": 0.95
      },
      "error_distribution": {
        "model": "Gaussian Mixture Model",
        "components": ["systematic_bias", "random_error", "tail_risk"],
        "percentiles_tracked": [50, 75, 90, 95, 99]
      }
    }
  },
  "tolerance_levels": {
    "exact": {
      "epsilon": 0.001,
      "description": "Near-zero tolerance for errors. Used when any deviation could cause harm or significant issues.",
      "use_cases": [
        "financial calculations",
        "security-critical operations",
        "legal document generation",
        "medical diagnoses",
        "data deletion",
        "authentication"
      ],
      "comparison_method": "exact",
      "skip_threshold": 1.0,
      "fallback_policy": "never_skip",
      "example_skills": ["finance", "legal-document-suite", "healthcare-compliance"],
      "validation_requirements": [
        "byte-level equality",
        "checksum verification",
        "cryptographic signature"
      ]
    },
    "close": {
      "epsilon": 0.05,
      "description": "Minor variations acceptable. Used when structure must be correct but minor details can vary.",
      "use_cases": [
        "code generation",
        "data transformations",
        "API requests",
        "file operations",
        "schema validation"
      ],
      "comparison_method": "structural",
      "skip_threshold": 0.95,
      "fallback_policy": "execute_with_validation",
      "example_skills": ["coding-agent", "data-transformer", "api-migrator", "xlsx", "docx"],
      "validation_requirements": [
        "schema compliance",
        "required field presence",
        "type correctness",
        "value range checks"
      ]
    },
    "approximate": {
      "epsilon": 0.20,
      "description": "Semantic equivalence sufficient. Used when meaning must be preserved but exact wording can vary.",
      "use_cases": [
        "content summarization",
        "classification tasks",
        "recommendations",
        "search rankings",
        "sentiment analysis"
      ],
      "comparison_method": "semantic",
      "skip_threshold": 0.85,
      "fallback_policy": "execute_if_low_confidence",
      "example_skills": ["blog-writer", "market-analyst", "sentiment-analyzer", "web-search"],
      "validation_requirements": [
        "semantic similarity > 0.80",
        "key entity preservation",
        "sentiment consistency",
        "topic alignment"
      ]
    },
    "behavioral": {
      "epsilon": 0.50,
      "description": "Same outcome category acceptable. Used when the general outcome matters more than specifics.",
      "use_cases": [
        "creative writing",
        "brainstorming",
        "exploratory analysis",
        "prototype generation",
        "ideation"
      ],
      "comparison_method": "behavioral",
      "skip_threshold": 0.70,
      "fallback_policy": "execute_on_request",
      "example_skills": ["fiction-writer", "world-builder", "storyboard-manager", "image-generation"],
      "validation_requirements": [
        "action type match",
        "outcome category match",
        "user intent satisfaction"
      ]
    }
  },
