  "safety_rules": {
    "never_skip": [
      "financial_transaction",
      "data_deletion",
      "security_operation",
      "legal_document_signing",
      "medical_diagnosis",
      "authentication",
      "authorization"
    ],
    "require_validation": [
      "api_key_usage",
      "pii_handling",
      "external_api_call",
      "database_write",
      "email_send"
    ],
    "max_consecutive_skips": 10,
    "recalibrate_triggers": {
      "error_rate_spike": 0.05,
      "consecutive_failures": 3,
      "user_complaint_rate": 0.02
    }
  },
  "escalation_levels": {
    "level_0": {
      "name": "Normal Operation",
      "condition": "All metrics within bounds",
      "action": "Skip execution when confidence >= threshold"
    },
    "level_1": {
      "name": "Caution",
      "condition": "Error rate > 2% above baseline",
      "action": "Increase confidence threshold by 5%"
    },
    "level_2": {
      "name": "Warning",
      "condition": "Error rate > 5% above baseline",
      "action": "Reduce skip rate by 50%, trigger recalibration"
    },
    "level_3": {
      "name": "Critical",
      "condition": "Error rate > 10% above baseline",
      "action": "Disable skip for affected skills, alert operations"
    },
    "level_4": {
      "name": "Emergency",
      "condition": "System-wide accuracy degradation",
      "action": "Disable tolerance system globally, require manual re-enablement"
    }
  },
  "metrics": {
    "efficiency": {
      "skip_rate": {
        "description": "Percentage of executions skipped due to high confidence",
        "target": "> 60% for approximate/behavioral tasks"
      },
      "average_latency_saved_ms": {
        "description": "Average time saved per skip",
        "target": "> 100ms per skip"
      },
      "token_savings": {
        "description": "Average tokens saved per skip",
        "target": "> 500 tokens per skip"
      }
    },
    "accuracy": {
      "false_skip_rate": {
        "description": "Skips where inferred output was outside tolerance",
        "target": "< 2%"
      },
      "error_rate_by_tolerance_level": {
        "description": "Error rates per tolerance band",
        "targets": {
          "exact": "< 0.1%",
          "close": "< 1%",
          "approximate": "< 5%",
          "behavioral": "< 10%"
        }
      }
    },
    "quality": {
      "user_satisfaction_score": {
        "description": "Post-execution user ratings",
        "target": "> 4.5/5.0"
      },
      "task_completion_rate": {
        "description": "Successful task completions",
        "target": "> 98%"
      },
      "revision_rate": {
        "description": "How often users request re-execution",
        "target": "< 5%"
      }
    }
  }
