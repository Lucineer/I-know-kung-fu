## schema.json Template

```json
{
  "name": "agent-name",
  "version": "1.0.0",
  "description": "Description here",
  "category": "productivity",
  "author": "SuperInstance",
  "tags": ["tag1", "tag2"],
  "rank": 1,
  "monetization_potential": "high",

  "inputs": {
    "type": "object",
    "properties": {
      "action": {
        "type": "string",
        "enum": ["action1", "action2"]
      }
    },
    "required": ["action"]
  },

  "outputs": {
    "type": "object",
    "properties": {
      "result": { "type": "string" }
    }
  },

  "capabilities": [
    "Capability 1",
    "Capability 2"
  ],

  "pricing": {
    "model": "tiered",
    "credits_per_use": {
      "action1": 1,
      "action2": 2
    }
  },

  "examples": [
    {
      "input": { "action": "action1" },
      "output": { "result": "..." }
    }
  ]
}
```

